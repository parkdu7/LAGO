# =================================================================
# LAGO 환경변수 템플릿
# 이 파일을 .env로 복사한 후 실제 값을 채워 넣으세요
# cp .env.example .env
# =================================================================

# Database (TimescaleDB/PostgreSQL)
POSTGRES_DB=stock_db
POSTGRES_USER=
POSTGRES_PASSWORD=
SPRING_DATASOURCE_URL=jdbc:postgresql://timescaledb:5432/stock_db
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Redis
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
REDIS_STREAM_KEY=orders-stream
REDIS_STREAM_CONSUMER_GROUP=lago_group
REDIS_STREAM_CONSUMER_NAME=lago_consumer

# KIS API (한국투자증권)
APP_KEY_A=
APP_SECRET_A=
APP_KEY_B=
APP_SECRET_B=

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:9000/login/oauth2/code/google

# Kakao OAuth2
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:9000/login/oauth2/code/kakao

# JWT
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRY=1800000
JWT_REFRESH_TOKEN_EXPIRY=604800000

# Firebase
FIREBASE_KEY_PATH=firebaseServiceAccountKey.json

# Naver News API (선택)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# AI 서비스 URL
FINBERT_URL=http://finbert-service:8000
CHART_ANALYSIS_URL=http://chart-analysis-service:8000

# Spring
SPRING_PROFILES_ACTIVE=dev

# 주가 시뮬레이터
PRICE_SIMULATOR_ENABLED=true
PRICE_SIMULATOR_VOLATILITY=1.0

# 뉴스 스케줄러
NEWS_SCHEDULER_ENABLED=true

# RabbitMQ (향후 도입 예정)
# RABBITMQ_HOST=rabbitmq
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD=guest
